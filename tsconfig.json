{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "allowJs": true,
    "checkJs": false
  },
  "include": ["**/*.ts", "**/*.js", "server.js", "index.js"],
  "exclude": ["node_modules", "dist"]
}
