// schema.prisma

// new prisma - must use pg in 7+ version
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

// Users
model User {
  id        String      @id @default(cuid())
  name      String
  email     String      @unique
  password  String
  refreshToken String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // relations
  workspaces UserWorkspace[]
  documents  Document[]
  revisions  Revision[]
  files      File[]
  activities Activity[]  // ua: зв'язок з активністю
  notifications Notification[]  // reletion with notifications

  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")
}


model Workspace {
  id          String      @id @default(cuid())
  name        String
  ownerId     String
  visibility  WorkspaceVisibility @default(PRIVATE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  owner       User        @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  users       UserWorkspace[]
  categories  Category[]
  activities  Activity[]  // ua: зв'язок з активністю
}

model UserWorkspace {
  id          String      @id @default(cuid())
  userId      String
  workspaceId String
  role        Role        @default(Owner) // Owner, Editor, Viewer, Admin, Guest
  createdAt   DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id])
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Category {
  id          String      @id @default(cuid())
  name        String
  workspaceId String
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents   Document[]
}

model Document {
  id          String      @id @default(cuid())
  title       String
  content     String
  categoryId  String
  ownerId     String
  visibility  DocumentVisibility @default(PRIVATE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  owner       User        @relation(fields: [ownerId], references: [id])
  files       File[]
  revisions   Revision[]
}

model File {
  id          String      @id @default(cuid())
  documentId  String
  ownerId     String
  fileName    String
  url         String
  size        Int
  createdAt   DateTime    @default(now())

  document    Document    @relation(fields: [documentId], references: [id])
  owner       User        @relation(fields: [ownerId], references: [id])
}

model Revision {
  id          String      @id @default(cuid())
  documentId  String
  editorId    String
  content     String
  createdAt   DateTime    @default(now())

  document    Document    @relation(fields: [documentId], references: [id])
  editor      User        @relation(fields: [editorId], references: [id])
}

// ua: Модель для логування активності у системі
model Activity {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  action      String   // ua: тип дії (напр. CREATE_DOCUMENT, UPLOAD_FILE)
  entityId    String?  // ua: ID об'єкта (документа, файлу тощо)
  entityName  String?  // ua: назва об'єкта для швидкого відображення в стрічці
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ua: Модель для внутрішніх сповіщень користувача
model Notification {
  id          String   @id @default(cuid())
  userId      String   // ua: кому призначене сповіщення
  title       String   // ua: заголовок (напр. "Нове запрошення")
  message     String   // ua: текст повідомлення
  type        String   // ua: тип (напр. "INVITE", "ROLE_CHANGE", "SYSTEM")
  isRead      Boolean  @default(false) // ua: чи прочитав користувач
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ENUMS

enum Role {
  Owner
  Editor
  Viewer
  Admin
  Guest
}

enum DocumentVisibility {
  PRIVATE
  PUBLIC
}

enum WorkspaceVisibility {
  PRIVATE
  PUBLIC
}